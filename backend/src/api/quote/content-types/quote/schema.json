{
  "kind": "collectionType",
  "collectionName": "quotes",
  "info": {
    "singularName": "quote",
    "pluralName": "quotes",
    "displayName": "Quote"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "date_create": {
      "type": "datetime",
      "required": true
    },
    "status_quote": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Borrador,",
        "Enviado,",
        "Aceptado, ",
        "Rechazado,"
      ]
    },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::customer.customer",
      "inversedBy": "quotes"
    },
    "services": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::service.service",
      "inversedBy": "quotes"
    }
  }
}
