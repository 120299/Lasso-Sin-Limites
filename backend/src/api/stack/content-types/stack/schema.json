{
  "kind": "collectionType",
  "collectionName": "stacks",
  "info": {
    "singularName": "stack",
    "pluralName": "stacks",
    "displayName": "Stack"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "projects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::project.project",
      "mappedBy": "stacks"
    }
  }
}
